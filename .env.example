# ─────────────────────────────────────────────
# Cyclone — Environment Variables Template
# Copy to .env and fill in values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# Application
FIRM_NAME=Your Law Firm
IS_DEVELOPMENT=false
HOST_URL=http://localhost:8000

# Logging
LOG_LEVEL=WARNING
# LOG_FORMAT=%(asctime)s - %(name)-15s - %(levelname)-8s - %(message)s

# ── Supabase ──────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_ANON_JWT_SECRET=

# ── LLM ───────────────────────────────────────
# Active vendor: gemini | openai | anthropic | groq | deepseek
LLM_VENDOR=gemini
LLM_FAST_VENDOR=gemini
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

GROQ_API_KEY=
GROQ_MODEL=groq/compound
GROQ_BASE_URL=https://api.groq.ai/v1/

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseekr.com/v1/

# ── Billing ───────────────────────────────────
# TIME_INCREMENT_OPTIONS=[0.1, 0.25, 0.5, 1.0]
# DEFAULT_REFRESH_TRIGGER_PCT=0.40

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Frontend (Vite build-time) ────────────────
# These go in .env.frontend (or frontend/.env)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_API_BASE_URL=http://localhost:8000
# VITE_STRIPE_PUBLISHABLE_KEY=
